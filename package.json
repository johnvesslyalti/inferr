    "prettier": "^3.4.2",
    "turbo": "^2.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "class-transformer": "^0.5.1",
