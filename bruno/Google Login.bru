meta {
  name: Google Login
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/auth/google
  body: none
  auth: none
}

docs {
  Open this URL in a browser — it redirects to Google's consent screen.
  After approving, Google redirects back to the API which then redirects to:

    http://localhost:3000/auth/callback?token=<your-user-uuid>

  Copy the token from that URL and set it as the `authToken` variable
  in the Bruno local environment, then use it in Get Feed and Chat requests.
}
